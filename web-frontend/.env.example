# Frontend Configuration
# For LOCAL DEVELOPMENT: set this to your local API server URL
# VITE_API_BASE_URL=http://localhost:3000
#
# For PRODUCTION (Render, etc.): set this to your backend API service's public URL
# Example for Render: VITE_API_BASE_URL=https://your-api-service-name.onrender.com
# You can set this as an environment variable in your Render frontend service dashboard

