# Database Configuration
# For Aiven MySQL database, use the following template below and replace placeholders
DATABASE_CLIENT=mysql2
DATABASE_URL=mysql://[USER]:[PASSWORD]@[HOST]:[PORT]/[DATABASE_NAME]?ssl-mode=REQUIRED
# Set DATABASE_URL example: mysql://avnadmin:yourpassword@your-host.aivencloud.com:port/dbname?ssl-mode=REQUIRED

# SSL Configuration (required for Aiven
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=true
# If you need to use a custom CA certificate, base64 encode it and set here
# DATABASE_CA_CERT_BASE64=

# JWT Configuration (required for production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-at-least-32-chars

# Server Configuration
PORT=3000
BIND_HOST=0.0.0.0
NODE_ENV=development
# Set to true if running behind proxy like Nginx/Apache etc
TRUST_PROXY=false

# CORS Configuration
# Frontend URL (for redirects and CORS)
FRONTEND_URL=http://localhost:5173
# Comma separated list of allowed origins, or * to allow all
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# File Upload Configuration
MAX_UPLOAD_BYTES=10485760
# Comma separated MIME types allowed
UPLOAD_MIME_ALLOWLIST=application/pdf,image/png,image/jpeg,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-powerpoint,application/vnd.openxmlformats-officedocument.presentationml.presentation

# Backup Configuration
ENABLE_ADMIN_RESTORE=false
BACKUP_INCLUDE_UPLOADS=false
BACKUP_KEEP=10

# Email Configuration (for two-factor auth and reminders)
# If not required for basic functionality
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="DENR Scheduler" <no-reply@denr.gov.ph>

# Timezone Configuration (e.g. Asia/Manila
APP_TIMEZONE=

# Data Storage Backend
# Set to "fs" to use local file storage instead of db
DATA_BACKEND=db
# Path to store data if using fs backend
DATA_DIR=./data

# Table prefix for database tables
DB_TABLE_PREFIX=

# Stream Token TTL in ms (for admin realtime events
STREAM_TOKEN_TTL_MS=120000
